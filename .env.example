# =============================================
# CONFIGURACIÓN DE ENTORNO - EJEMPLO
# =============================================
# Copia este archivo como .env y configura tus valores

# URL del Backend API
VITE_API_URL=http://localhost:5000/api

# Nombre de la aplicación
VITE_APP_NAME=DR CELL 2.0

# Entorno (development, production)
VITE_ENV=development

# =============================================
# CONFIGURACIÓN PARA PRODUCCIÓN
# =============================================
# VITE_API_URL=https://api.tudominio.com/api
# VITE_ENV=production
# VITE_APP_NAME=DR CELL 2.0

# =============================================
# NOTAS IMPORTANTES
# =============================================
# 1. Las variables en Vite DEBEN empezar con VITE_
# 2. Después de cambiar .env, reinicia el servidor de desarrollo
# 3. NUNCA subas el archivo .env al repositorio
# 4. En producción, configura estas variables en tu servicio de hosting

